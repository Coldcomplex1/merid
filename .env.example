# Firebase web app config — copy to .env.local and fill in the values from
# Firebase Console → Project settings → Your apps → SDK setup and configuration.
#
# NOTE: these values identify the project, they are not secrets — real access
# control lives in firestore.rules and the API-key restrictions described in
# docs/FIREBASE_SETUP.md. Still keep .env.local out of git so each environment
# (dev/prod) can point at its own project.
#
# All vars are OPTIONAL: when absent the app falls back to Merid's public
# project identifiers (src/lib/firebase.ts) so login never silently disappears
# on a deploy with missing env config. Only API_KEY / AUTH_DOMAIN / PROJECT_ID
# affect auth + Firestore; the rest are passed through when set.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
